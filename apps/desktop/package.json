{
  "name": "localtube-desktop",
  "version": "0.1.0",
  "private": true,
  "author": "LocalTube Team",
  "main": "main.js",
  "description": "LocalTube Saver desktop app",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.localtube.saver",
    "productName": "LocalTube Saver",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "express": "4.19.2",
    "ffmpeg-static": "5.2.0",
    "ffprobe-static": "3.1.0",
    "qrcode": "1.5.3",
    "sanitize-filename": "1.6.3"
  },
  "devDependencies": {
    "electron": "31.3.1",
    "electron-builder": "^26.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "ffmpeg-static",
      "electron-winstaller"
    ]
  }
}
