{
  "name": "localtube-desktop",
  "version": "0.4.0",
  "private": true,
  "author": "LocalTube Team",
  "main": "dist-tsc/main.js",
  "description": "LocalTube Saver desktop app",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitkojine/localtube-saver.git"
  },
  "scripts": {
    "start": "pnpm run build:ts && electron .",
    "build:ts": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json",
    "lint": "eslint .",
    "build": "pnpm run build:ts && electron-builder"
  },
  "build": {
    "appId": "com.localtube.saver",
    "productName": "LocalTube Saver",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bitkojine",
        "repo": "localtube-saver",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "LocalTube-Saver-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "LocalTube-Saver-${version}.${ext}"
    }
  },
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "4.19.2",
    "ffmpeg-static": "5.2.0",
    "ffprobe-static": "3.1.0",
    "qrcode": "1.5.3",
    "sanitize-filename": "1.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^9.14.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "electron": "31.3.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-no-comments": "^1.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
