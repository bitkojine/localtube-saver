{
  "name": "localtube-desktop",
  "version": "0.1.1",
  "private": true,
  "author": "LocalTube Team",
  "main": "main.js",
  "description": "LocalTube Saver desktop app",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitkojine/localtube-saver.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.localtube.saver",
    "productName": "LocalTube Saver",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bitkojine",
        "repo": "localtube-saver",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "LocalTube-Saver-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "LocalTube-Saver-${version}.${ext}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "4.19.2",
    "ffmpeg-static": "5.2.0",
    "ffprobe-static": "3.1.0",
    "qrcode": "1.5.3",
    "sanitize-filename": "1.6.3"
  },
  "devDependencies": {
    "electron": "31.3.1",
    "electron-builder": "^26.8.1"
  }
}
