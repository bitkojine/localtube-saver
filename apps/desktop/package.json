{
  "name": "localtube-desktop",
  "version": "0.4.8",
  "private": true,
  "author": "LocalTube Team",
  "main": "dist-tsc/main.js",
  "description": "LocalTube Saver desktop app",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitkojine/localtube-saver.git"
  },
  "scripts": {
    "start": "npm run build:ts && electron .",
    "build:ts": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json",
    "lint": "eslint .",
    "build": "npm run build:ts && electron-builder --publish=never"
  },
  "build": {
    "appId": "com.localtube.saver",
    "productName": "LocalTube Saver",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bitkojine",
        "repo": "localtube-saver",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "LocalTube-Saver-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "LocalTube-Saver-${version}.${ext}"
    }
  },
  "type": "commonjs",
  "dependencies": {
    "ee-first": "1.1.1",
    "electron-updater": "^6.8.3",
    "express": "4.22.1",
    "ffmpeg-static": "5.3.0",
    "ffprobe-static": "3.1.0",
    "qrcode": "1.5.4",
    "sanitize-filename": "1.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "electron": "31.3.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-plugin-no-comments": "^1.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
